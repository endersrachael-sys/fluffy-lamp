# Required for live Claude reasoning
ANTHROPIC_API_KEY=replace_me

# Claude model used by the agent loop
CLAUDE_MODEL=claude-sonnet-4-6

# Production/runtime flags
NODE_ENV=production
LIVE_LLM_MODE=true
LIVE_APIS=true

# Render provides PORT automatically in production.
# Use 3000 locally if needed.
PORT=3000

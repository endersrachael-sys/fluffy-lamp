# JarDIYn environment
# Never commit real secrets. Set these in Render Dashboard > Environment.

# Required for live Claude agent mode. Without this, the app runs in transparent fallback mode.
ANTHROPIC_API_KEY=

# Optional. Keep configurable because model names evolve.
ANTHROPIC_MODEL=

# Set true to force fallback mode for demos/tests without LLM calls.
FORCE_FALLBACK_AGENT=false

# Optional: enables extra sanitized debug endpoint details. No secrets are ever returned.
ENABLE_DEBUG_ROUTES=true

# Optional: lets no-key weather/soil calls run where available.
LIVE_APIS=true

# Render injects PORT automatically.
PORT=3000
